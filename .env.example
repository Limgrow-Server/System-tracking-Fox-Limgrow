# Supabase browser/server client
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<supabase-publishable-key>"

# Optional Supabase Auth admin operations, server-side only.
# Enables inviteUserByEmail and Auth app_metadata sync in /users.
# SUPABASE_SERVICE_ROLE_KEY="<supabase-service-role-or-secret-key>"

# Credential secret OTP email, server-side only.
# Used before revealing hidden Config credential keys.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your@gmail.com
# SMTP_PASS=app-password
# Optional if the OTP recipient differs from SMTP_USER.
# SMTP_TO=security@example.com
# Optional separate HMAC secret. Falls back to SUPABASE_SERVICE_ROLE_KEY.
# CREDENTIAL_OTP_SECRET="<long-random-secret>"

# App Store Server Notifications V2 webhook verification.
# Download Apple root certificates from https://www.apple.com/certificateauthority/
# and provide either local certificate paths, DER base64 values, or PEM content.
# APPLE_APP_STORE_ROOT_CERTIFICATE_PATHS="C:\\certs\\AppleRootCA-G3.cer"
# APPLE_APP_STORE_ROOT_CERTIFICATES_BASE64="<der-base64>,<der-base64>"
# APPLE_APP_STORE_ROOT_CERTIFICATES_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# Optional. Set false only for local testing when OCSP/network checks are not desired.
# APPLE_APP_STORE_ENABLE_ONLINE_CHECKS="true"

# Prisma / Supabase Postgres
# Runtime connection. Use the Supabase Session Pooler or direct connection string.
DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# Migration connection. Prefer Supabase direct connection or Session Pooler.
DIRECT_URL="postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
