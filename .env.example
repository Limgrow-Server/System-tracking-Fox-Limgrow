# Supabase browser/server client
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<supabase-publishable-key>"
# Public console origin used for auth callback redirects behind reverse proxies.
# NEXT_PUBLIC_SITE_URL="https://tracking-platform.example.com"

# NestJS backend URL. Next.js rewrites /api/* to this backend when configured.
# Mobile can also use this domain with the same /functions/v1/* paths.
# Defaults to http://127.0.0.1:2156 when unset.
# SYSTEM_TRACKING_API_URL="https://tracking-api.example.com"
# SYSTEM_TRACKING_API_PORT=2156
# SYSTEM_TRACKING_FUNCTIONS_BASE_URL="https://tracking-api.example.com"

# Legacy Supabase Edge proxy env. Keep only while old Edge proxy is still deployed.
# TRACKING_SERVER_URL="https://tracking-platform.example.com"

# Optional Supabase Auth admin operations, server-side only.
# Enables inviteUserByEmail and Auth app_metadata sync in /users.
# SUPABASE_SERVICE_ROLE_KEY="<supabase-service-role-or-secret-key>"

# Queued notification worker auth, server-side only.
# Must match the Supabase Edge Function secret for send-notification.
# NOTIFICATION_QUEUE_SECRET="<long-random-secret>"
# NOTIFICATION_DISPATCH_SECRET="<same-long-random-secret>"
# NOTIFICATION_QUEUE_ENABLED=true
# NOTIFICATION_QUEUE_INTERVAL_MS=10000
# NOTIFICATION_QUEUE_BATCH_SIZE=100
# NOTIFICATION_QUEUE_CLAIM_LIMIT=4

# Mobile token/event ingest worker, server-side only.
# Falls back to NOTIFICATION_QUEUE_SECRET when MOBILE_INGEST_SECRET is empty.
# MOBILE_INGEST_SECRET="<long-random-secret>"
# MOBILE_INGEST_ENABLED=true
# MOBILE_INGEST_DATABASE_CONNECTION_LIMIT=6
# MOBILE_INGEST_DATABASE_POOL_TIMEOUT=10
# MOBILE_INGEST_INTERVAL_MS=5000
# MOBILE_INGEST_ACTIVE_INTERVAL_MS=250
# MOBILE_INGEST_BATCH_SIZE=100
# MOBILE_INGEST_CONCURRENCY=3
# MOBILE_INGEST_ENQUEUE_CONCURRENCY=3
# MOBILE_INGEST_WORKER_CONNECTION_RESERVE=2
# MOBILE_INGEST_LOCK_TTL_MS=600000
# MOBILE_INGEST_MAX_ATTEMPTS=5
# MOBILE_INGEST_DEDUPE_COOLDOWN_MS=21600000
# MOBILE_INGEST_SPOOL_PATH=".runtime/mobile-ingest-events.jsonl"
# MOBILE_INGEST_SPOOL_DRAIN_LIMIT=50

# Background cron toggles, server-side only.
# REVIEW_FETCH_CRON_ENABLED=true
# REVIEW_FETCH_INTERVAL_MS=180000
# IOS_IAP_2HOUR_ENABLED=true
# IOS_IAP_2HOUR_CHECK_INTERVAL_MS=60000

# Credential secret OTP email, server-side only.
# Used before revealing hidden Config credential keys.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your@gmail.com
# SMTP_PASS=app-password
# Optional if the OTP recipient differs from SMTP_USER.
# SMTP_TO=security@example.com
# Optional separate HMAC secret. Falls back to SUPABASE_SERVICE_ROLE_KEY.
# CREDENTIAL_OTP_SECRET="<long-random-secret>"

# App Store Server Notifications V2 webhook verification.
# Download Apple root certificates from https://www.apple.com/certificateauthority/
# and provide either local certificate paths, DER base64 values, or PEM content.
# APPLE_APP_STORE_ROOT_CERTIFICATE_PATHS="C:\\certs\\AppleRootCA-G3.cer"
# APPLE_APP_STORE_ROOT_CERTIFICATES_BASE64="<der-base64>,<der-base64>"
# APPLE_APP_STORE_ROOT_CERTIFICATES_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# Optional. Set false only for local testing when OCSP/network checks are not desired.
# APPLE_APP_STORE_ENABLE_ONLINE_CHECKS="true"

# Event tracking database: IAP, reviews, mappings, credentials, and analytics events.
EVENT_TRACKING_DATABASE_URL="postgresql://postgres.<tracking-project-ref>:<tracking-db-password>@<tracking-region>.pooler.supabase.com:5432/postgres?sslmode=require"
EVENT_TRACKING_DIRECT_URL="postgresql://postgres:<tracking-db-password>@db.<tracking-project-ref>.supabase.co:5432/postgres?sslmode=require"

# Notification database: device tokens, notification events, jobs, batches, and schedules.
# The server deploy applies the same Prisma migration set to both databases.
NOTIFICATION_DATABASE_URL="postgresql://postgres.<notification-project-ref>:<notification-db-password>@<notification-region>.pooler.supabase.com:5432/postgres?sslmode=require"
NOTIFICATION_DIRECT_URL="postgresql://postgres:<notification-db-password>@db.<notification-project-ref>.supabase.co:5432/postgres?sslmode=require"

# Prisma CLI compatibility and fallback. Keep these equal to the tracking database.
DATABASE_URL="postgresql://postgres.<tracking-project-ref>:<tracking-db-password>@<tracking-region>.pooler.supabase.com:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:<tracking-db-password>@db.<tracking-project-ref>.supabase.co:5432/postgres?sslmode=require"
