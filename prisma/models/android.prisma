model AndroidStoreProfile {
  id               String                @id @default(uuid()) @db.Uuid
  storeAccountName String                @unique @map("store_account_name")
  linkStore        String?               @map("link_store")
  avatarUrl        String?               @map("avatar_url")
  contactEmail     String?               @map("contact_email")
  supportPhone     String?               @map("support_phone")
  websiteUrl       String?               @map("website_url")
  status           MappingStatus         @default(ACTIVE)
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  mappings         AndroidStoreMapping[]
  credentials      AndroidCredential[]
  iapTransactions  IapAndroid[]

  @@index([status, storeAccountName], map: "android_store_profiles_status_name_idx")
  @@map("android_store_profiles")
}

model AndroidStoreMapping {
  id               String                            @id @default(uuid()) @db.Uuid
  storeProfileId   String                            @map("store_profile_id") @db.Uuid
  storeAccountName String                            @map("store_account_name")
  appId            String?                           @map("app_id")
  appName          String                            @map("app_name")
  appIconUrl       String?                           @map("app_icon_url")
  appLink          String?                           @map("app_link")
  packageName      String                            @map("package_name")
  status           MappingStatus                     @default(ACTIVE)
  createdAt        DateTime                          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                          @updatedAt @map("updated_at") @db.Timestamptz(6)
  storeProfile     AndroidStoreProfile               @relation(fields: [storeProfileId], references: [id], onDelete: Restrict)
  reviews          AndroidStoreReview[]
  reviewSyncState  AndroidStoreReviewSyncState?
  reviewFetchRuns  AndroidStoreReviewFetchRun[]
  reviewFetchSchedule AndroidStoreReviewFetchSchedule?
  replyTemplates   AndroidStoreReviewReplyTemplate[]

  @@unique([storeProfileId, appName], map: "android_store_mappings_profile_app_name_key")
  @@unique([storeProfileId, appId], map: "android_store_mappings_profile_app_id_key")
  @@unique([packageName], map: "android_store_mappings_package_key")
  @@index([appId, status], map: "android_store_mappings_app_id_status_idx")
  @@index([packageName, status], map: "android_store_mappings_package_status_idx")
  @@index([storeAccountName], map: "android_store_mappings_store_name_idx")
  @@map("android_store_mappings")
}

model AndroidStoreReview {
  id                      String              @id @default(uuid()) @db.Uuid
  storeMappingId          String              @map("store_mapping_id") @db.Uuid
  reviewId                String              @map("review_id")
  authorName              String?             @map("author_name")
  rating                  Int?
  reviewText              String?             @map("review_text") @db.Text
  originalText            String?             @map("original_text") @db.Text
  reviewerLanguage        String?             @map("reviewer_language")
  device                  String?
  deviceMetadata          Json?               @map("device_metadata")
  androidOsVersion        Int?                @map("android_os_version")
  appVersionCode          Int?                @map("app_version_code")
  appVersionName          String?             @map("app_version_name")
  thumbsUpCount           Int?                @map("thumbs_up_count")
  thumbsDownCount         Int?                @map("thumbs_down_count")
  userCommentUpdatedAt    DateTime?           @map("user_comment_updated_at") @db.Timestamptz(6)
  developerReplyText      String?             @map("developer_reply_text") @db.Text
  developerReplyUpdatedAt DateTime?           @map("developer_reply_updated_at") @db.Timestamptz(6)
  rawReview               Json?               @map("raw_review")
  fetchedAt               DateTime            @default(now()) @map("fetched_at") @db.Timestamptz(6)
  createdAt               DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  storeMapping            AndroidStoreMapping @relation(fields: [storeMappingId], references: [id], onDelete: Cascade)

  @@unique([storeMappingId, reviewId], map: "android_store_reviews_mapping_review_key")
  @@index([storeMappingId, userCommentUpdatedAt], map: "android_store_reviews_mapping_user_updated_idx")
  @@index([storeMappingId, rating], map: "android_store_reviews_mapping_rating_idx")
  @@index([developerReplyUpdatedAt], map: "android_store_reviews_reply_updated_idx")
  @@map("android_store_reviews")
}

model AndroidStoreReviewSyncState {
  id                  String              @id @default(uuid()) @db.Uuid
  storeMappingId      String              @unique @map("store_mapping_id") @db.Uuid
  status              ReviewSyncStatus    @default(IDLE)
  lastFetchStartedAt  DateTime?           @map("last_fetch_started_at") @db.Timestamptz(6)
  lastFetchFinishedAt DateTime?           @map("last_fetch_finished_at") @db.Timestamptz(6)
  lastSuccessAt       DateTime?           @map("last_success_at") @db.Timestamptz(6)
  lastReviewUpdatedAt DateTime?           @map("last_review_updated_at") @db.Timestamptz(6)
  lockedAt            DateTime?           @map("locked_at") @db.Timestamptz(6)
  lockedBy            String?             @map("locked_by")
  lastErrorCode       String?             @map("last_error_code")
  lastErrorMessage    String?             @map("last_error_message") @db.Text
  lastFetchedCount    Int                 @default(0) @map("last_fetched_count")
  lastUpsertedCount   Int                 @default(0) @map("last_upserted_count")
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  storeMapping        AndroidStoreMapping @relation(fields: [storeMappingId], references: [id], onDelete: Cascade)

  @@index([status, lastFetchStartedAt], map: "android_store_review_sync_states_status_started_idx")
  @@index([lastSuccessAt], map: "android_store_review_sync_states_success_idx")
  @@map("android_store_review_sync_states")
}

model AndroidStoreReviewFetchRun {
  id              String               @id @default(uuid()) @db.Uuid
  storeMappingId  String               @map("store_mapping_id") @db.Uuid
  triggerType     ReviewFetchTrigger   @default(SCHEDULED) @map("trigger_type")
  status          ReviewFetchRunStatus @default(RUNNING)
  maxResults      Int                  @default(100) @map("max_results")
  maxPages        Int                  @default(2) @map("max_pages")
  pagesFetched    Int                  @default(0) @map("pages_fetched")
  reviewsFetched  Int                  @default(0) @map("reviews_fetched")
  reviewsUpserted Int                  @default(0) @map("reviews_upserted")
  errorCode       String?              @map("error_code")
  errorMessage    String?              @map("error_message") @db.Text
  startedAt       DateTime             @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt      DateTime?            @map("finished_at") @db.Timestamptz(6)
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  storeMapping    AndroidStoreMapping  @relation(fields: [storeMappingId], references: [id], onDelete: Cascade)

  @@index([storeMappingId, startedAt], map: "android_store_review_fetch_runs_mapping_started_idx")
  @@index([status, startedAt], map: "android_store_review_fetch_runs_status_started_idx")
  @@map("android_store_review_fetch_runs")
}

model AndroidStoreReviewFetchSchedule {
  id              String                    @id @default(uuid()) @db.Uuid
  storeMappingId  String                    @unique @map("store_mapping_id") @db.Uuid
  status          ReviewFetchScheduleStatus @default(ACTIVE)
  scheduleType    String                    @default("daily") @map("schedule_type")
  timeOfDay       String                    @default("09:00") @map("time_of_day")
  timezone        String                    @default("Asia/Ho_Chi_Minh")
  lookbackDays    Int                       @default(7) @map("lookback_days")
  maxResults      Int                       @default(100) @map("max_results")
  maxPages        Int                       @default(2) @map("max_pages")
  nextRunAt       DateTime                  @map("next_run_at") @db.Timestamptz(6)
  lastRunAt       DateTime?                 @map("last_run_at") @db.Timestamptz(6)
  lastStatus      ReviewFetchRunStatus?     @map("last_status")
  lastErrorMessage String?                  @map("last_error_message") @db.Text
  lockedAt        DateTime?                 @map("locked_at") @db.Timestamptz(6)
  lockedBy        String?                   @map("locked_by")
  runCount        Int                       @default(0) @map("run_count")
  createdBy       String?                   @map("created_by")
  updatedBy       String?                   @map("updated_by")
  createdAt       DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  storeMapping    AndroidStoreMapping       @relation(fields: [storeMappingId], references: [id], onDelete: Cascade)

  @@index([status, nextRunAt], map: "android_store_review_fetch_schedules_status_next_idx")
  @@index([lockedAt], map: "android_store_review_fetch_schedules_locked_idx")
  @@map("android_store_review_fetch_schedules")
}

model AndroidStoreReviewReplyTemplate {
  id             String              @id @default(uuid()) @db.Uuid
  storeMappingId String              @map("store_mapping_id") @db.Uuid
  rating         Int
  replyText      String              @map("reply_text") @db.Text
  isActive       Boolean             @default(false) @map("is_active")
  createdBy      String?             @map("created_by")
  updatedBy      String?             @map("updated_by")
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  storeMapping   AndroidStoreMapping @relation(fields: [storeMappingId], references: [id], onDelete: Cascade)

  @@unique([storeMappingId, rating], map: "android_store_review_reply_templates_mapping_rating_key")
  @@index([storeMappingId, isActive], map: "android_store_review_reply_templates_mapping_active_idx")
  @@map("android_store_review_reply_templates")
}

model AndroidCredential {
  id                 String              @id @default(uuid()) @db.Uuid
  storeProfileId     String              @map("store_profile_id") @db.Uuid
  credentialRef      String              @unique @map("credential_ref")
  vaultSecretId      String?             @map("vault_secret_id") @db.Uuid
  vaultSecretName    String?             @map("vault_secret_name")
  vaultSecretVersion Int                 @default(1) @map("vault_secret_version")
  storeAccountName   String              @map("store_account_name")
  linkStore          String?             @map("link_store")
  avatarUrl          String?             @map("avatar_url")
  privateKeyId       String?             @map("private_key_id")
  clientEmail        String?             @map("client_email")
  projectId          String?             @map("project_id")
  status             CredentialStatus    @default(ACTIVE)
  description        String?
  createdBy          String?             @map("created_by")
  rotatedBy          String?             @map("rotated_by")
  lastUsedAt         DateTime?           @map("last_used_at") @db.Timestamptz(6)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  storeProfile       AndroidStoreProfile @relation(fields: [storeProfileId], references: [id], onDelete: Restrict)

  @@unique([storeProfileId], map: "android_credentials_profile_key")
  @@index([credentialRef, status], map: "android_credentials_lookup_idx")
  @@index([storeAccountName, status], map: "android_credentials_store_status_idx")
  @@index([vaultSecretId], map: "android_credentials_vault_secret_id_idx")
  @@index([vaultSecretName], map: "android_credentials_vault_secret_name_idx")
  @@map("android_credentials")
}

model IapAndroid {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeProfileId      String?   @map("store_profile_id") @db.Uuid
  packageName         String    @map("package_name")
  productId           String    @map("product_id")
  purchaseKind        String    @map("purchase_kind")
  purchaseToken       String    @map("purchase_token")
  orderId             String?   @map("order_id")
  linkedPurchaseToken String?   @map("linked_purchase_token")
  state               String
  acknowledged        Boolean   @default(false)
  consumed            Boolean?
  autoRenewing        Boolean?  @map("auto_renewing")
  purchaseDate        DateTime? @map("purchase_date") @db.Timestamptz(6)
  expiresDate         DateTime? @map("expires_date") @db.Timestamptz(6)
  revenueMicros       BigInt?   @map("revenue_micros")
  currency            String?
  regionCode          String?   @map("region_code")
  basePlanId          String?   @map("base_plan_id")
  offerId             String?   @map("offer_id")
  isTestPurchase      Boolean   @default(false) @map("is_test_purchase")
  rawReceipt          Json?     @map("raw_receipt")
  verifiedAt          DateTime  @map("verified_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  storeProfile AndroidStoreProfile? @relation(fields: [storeProfileId], references: [id], onDelete: SetNull)

  @@unique([packageName, purchaseToken])
  @@index([packageName, productId])
  @@index([state, purchaseDate])
  @@index([storeProfileId])
  @@map("iap_android")
}
